// .devcontainer/devcontainer.json
{
  "name": "Route ArcGIS Angular",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // Set the remote user to 'node' (provided by the base image)
  // to avoid permission issues with node_modules
  "remoteUser": "node",

  "features": {
    // Adds common utilities securely
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      },
      // Essential extensions for Angular development
      "extensions": [
        "Angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "editorconfig.editorconfig",
        "johnpapa.Angular2",
        "infinity1207.angular2-switcher",
        "formulahendry.auto-rename-tag"
      ]
    }
  },

  // Forward the default Angular port
  "forwardPorts": [4200],

  // Run the setup script automatically when the container is created
  "postCreateCommand": "bash .devcontainer/setup.sh",

  // Lifecycle scripts
  "postStartCommand": "echo 'Container started. Run \"npm start\" to serve.'"
}
